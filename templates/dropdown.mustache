{{!
    @template tool_mulib/dropdown

    Simple dropdown with actions.

    Example context (json):
    {
        "title": "Actions",
        "items": [
            { "divider": true },
            { "url": "https://example.com/something.php", "label": "Something" },
            { "customhtml": "<a class=\"dropdown-item\" href=\"https://example.com/other.php\">Other link</a>" }
        ]
    }
}}
<div class="btn-group">
    <a href="#" class="btn btn-link btn-icon icon-size-3 rounded-circle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="{{title}}">
        <i class="fa fa-ellipsis-v text-dark py-2" aria-hidden="true"></i>
    </a>
    <div class="dropdown-menu dropdown-menu-right">
        {{#items}}
            {{#divider}}
                <div class="dropdown-divider"></div>
            {{/divider}}
            {{#url}}
                <a class="dropdown-item" href="{{url}}">{{label}}</a>
            {{/url}}
            {{#customhtml}}
                {{{.}}}
            {{/customhtml}}
        {{/items}}
    </div>
</div>
