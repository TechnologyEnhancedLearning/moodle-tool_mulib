{{!
    @template tool_mulib/dialog_form/button

    Dialog form launch button.

    Example context (json):
    {
        "title": "Actions",
        "formurl": "https://example.com/something.php",
        "dialogname": "Some dialog",
        "aftersubmit": "reload",
        "class": "xl",
        "disabled": false,
        "legacyformtest": false,
        "icon": "<i class=\"icon fa fa-cog fa-fw\" aria-hidden=\"true\" title=\"Edit\" aria-label=\"\"></i>",
        "priamry": 1
    }
}}
{{#disabled}}
<button disabled class="btn btn-secondary {{class}}">{{{icon}}}{{title}}</button>
{{/disabled}}
{{^disabled}}
{{#legacyformtest}}
<form method="post" action="{{formurl}}">
<button
  class="btn {{#primary}}btn-primary{{/primary}}{{^primary}}btn-secondary{{/primary}} {{class}}">{{{icon}}}{{title}}</button>
</form>
{{/legacyformtest}}
{{^legacyformtest}}
<noscript><form method="get" action="{{formurl}}"><button type="submit">{{title}}</button></form></noscript>
<button id="dialog-form-action-{{uniqid}}"
  data-form-url="{{formurl}}" data-dialog-name="{{dialogname}}" data-after-submit="{{aftersubmit}}" data-dialog-size="{{dialogsize}}"
  class="btn {{#primary}}btn-primary{{/primary}}{{^primary}}btn-secondary{{/primary}} {{class}}">{{{icon}}}{{title}}</button>

{{#js}}
require([
    'tool_mulib/dialog_form',
], function(DialogForm) {
    let action = document.getElementById('dialog-form-action-{{uniqid}}');

    action.onclick = function() {
        new DialogForm({
            modalConfig: {title: action.dataset.dialogName},
            triggerElement: action,
            formUrl: action.dataset.formUrl,
            afterSubmit: action.dataset.afterSubmit,
            size: action.dataset.dialogSize,
        });
    };
});
{{/js}}
{{/legacyformtest}}
{{/disabled}}
